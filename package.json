{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "prepare": "husky || true",
        "lint": "eslint resources/js --fix",
        "lint:check": "eslint resources/js",
        "prettier": "prettier --write \"resources/**/*.{js,vue,css}\" \"**/*.{json,md,yml,yaml}\" --ignore-path .gitignore",
        "prettier:check": "prettier --check \"resources/**/*.{js,vue,css}\" \"**/*.{json,md,yml,yaml}\" --ignore-path .gitignore",
        "format": "npm run prettier && npm run lint",
        "check": "npm run lint:check && npm run prettier:check"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@tailwindcss/vite": "^4.2.4",
        "@vitejs/plugin-vue": "^6.0.6",
        "concurrently": "^9.2.1",
        "eslint": "^10.2.1",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-vue": "^10.9.0",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^3.0.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "prettier-plugin-organize-attributes": "^1.0.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.2.4",
        "vite": "^8.0.9",
        "vue-eslint-parser": "^10.4.0"
    },
    "dependencies": {
        "@heroicons/vue": "^2.2.0",
        "@inertiajs/vite": "^3.0.3",
        "@inertiajs/vue3": "^3.0.3",
        "@sentry/vite-plugin": "^5.2.0",
        "@sentry/vue": "^10.49.0",
        "@vue/server-renderer": "^3.5.33",
        "vue": "^3.5.33"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.60.2",
        "@rollup/rollup-win32-x64-msvc": "4.60.2",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.2.4",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.2.4",
        "lightningcss-linux-x64-gnu": "^1.32.0",
        "lightningcss-win32-x64-msvc": "^1.32.0"
    },
    "lint-staged": {
        "resources/js/**/*.{js,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "**/*.{css,scss,html,json,md,yml,yaml}": [
            "prettier --write"
        ],
        "**/*.php": [
            "php ./vendor/bin/pint --config=pint.json"
        ]
    }
}
