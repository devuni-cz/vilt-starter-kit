{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "prettier": "prettier --write \"resources/**/*.{js,vue,css}\" \"*.{js,json}\"",
        "pint": "php vendor/bin/pint . --config=pint.json",
        "rector": "php vendor/bin/rector process",
        "analyse": "php vendor/bin/phpstan analyse --memory-limit=8G",
        "lint": "eslint resources/js --fix",
        "lint:check": "eslint resources/js",
        "format": "npm run prettier && npm run pint && npm run lint"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@tailwindcss/vite": "^4.2.2",
        "@vitejs/plugin-vue": "^6.0.5",
        "concurrently": "^9.2.1",
        "eslint": "^10.2.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "laravel-vite-plugin": "^3.0.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-attributes": "^1.0.0",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "tailwindcss": "^4.2.2",
        "vite": "^8.0.5",
        "vue-eslint-parser": "^10.4.0"
    },
    "dependencies": {
        "@heroicons/vue": "^2.2.0",
        "@inertiajs/vite": "^3.0.2",
        "@inertiajs/vue3": "^3.0.2",
        "@sentry/tracing": "^7.120.4",
        "@sentry/vite-plugin": "^5.1.1",
        "@sentry/vue": "^10.47.0",
        "@vue/server-renderer": "^3.5.32",
        "vue": "^3.5.32"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.60.1",
        "@rollup/rollup-win32-x64-msvc": "4.60.1",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
        "lightningcss-linux-x64-gnu": "^1.32.0",
        "lightningcss-win32-x64-msvc": "^1.32.0"
    },
    "lint-staged": {
        "resources/js/**/*.{js,vue}": [
            "eslint --fix",
            "prettier --write"
        ],
        "**/*.{css,scss,html,json,md}": [
            "prettier --write"
        ],
        "**/*.php": [
            "php ./vendor/bin/pint --config=pint.json"
        ]
    }
}
